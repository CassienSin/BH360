# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api

# Firebase Configuration
# Get these values from Firebase Console > Project Settings > General > Your apps
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Firebase Cloud Messaging (Push Notifications)
# Get VAPID key from Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
# Generate a key pair if one doesn't exist, then copy the PUBLIC key
VITE_FIREBASE_VAPID_KEY=your_firebase_vapid_key_here

# Optional: Email address for automatic admin promotion (set to empty if not needed)
VITE_ADMIN_EMAIL=admin@example.com

# Firebase Emulators (for local development)
# Set to 'true' to use Firebase emulators instead of production Firebase
VITE_USE_FIREBASE_EMULATORS=false
